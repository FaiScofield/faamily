<!-- Family page: family info card, scenario templates, invite code -->
<view class="page-family">
  <!-- Loading state -->
  <view wx:if="{{loading}}" class="loading-container">
    <loading />
  </view>

  <!-- Main content -->
  <view wx:else class="family-content">
    <!-- Family Info Card -->
    <view class="card family-card">
      <view class="family-card-header">
        <view class="family-avatar">
          <image
            src="{{family.avatar_url || '/images/icon-family.png'}}"
            mode="aspectFill"
          />
        </view>
        <view class="family-info">
          <text class="family-name">{{family.name || '未命名家庭'}}</text>
          <text class="family-role">角色: {{roleLabel}}</text>
        </view>
      </view>
      <view class="family-stats">
        <view class="stat-item">
          <text class="stat-value">{{memberCount || 0}}</text>
          <text class="stat-label">成员</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{activeTemplateCount || 0}}</text>
          <text class="stat-label">场景</text>
        </view>
      </view>
    </view>

    <!-- Invite Code Section -->
    <view class="card invite-section">
      <view class="section-header">
        <text class="section-title">邀请码</text>
        <button class="btn-invite" bindtap="generateInviteCode">生成邀请码</button>
      </view>
      <view wx:if="{{inviteCode}}" class="invite-code-box">
        <text class="invite-code-label">邀请码:</text>
        <text class="invite-code-value">{{inviteCode}}</text>
        <button class="btn-copy" bindtap="copyInviteCode">复制</button>
      </view>
      <view wx:else class="invite-empty">
        <text class="invite-empty-text">生成邀请码邀请家人加入</text>
      </view>
    </view>

    <!-- Scenario Templates Section -->
    <view class="card template-section">
      <view class="section-header">
        <text class="section-title">场景模板</text>
        <button wx:if="{{templates.length === 0}}" class="btn-init" bindtap="initTemplates" loading="{{initLoading}}">一键初始化</button>
      </view>

      <!-- Template list -->
      <view wx:if="{{templates.length > 0}}" class="template-list">
        <view
          wx:for="{{templates}}"
          wx:key="template_id"
          class="template-item"
        >
          <view class="template-icon">{{item.icon || '📋'}}</view>
          <view class="template-info">
            <text class="template-name">{{item.name}}</text>
            <text wx:if="{{item.description}}" class="template-desc">{{item.description}}</text>
          </view>
          <view class="template-status">
            <text wx:if="{{item.is_enabled}}" class="tag-enabled">已启用</text>
            <text wx:else class="tag-disabled">未启用</text>
          </view>
        </view>
      </view>

      <!-- Empty template -->
      <view wx:else class="template-empty">
        <text class="template-empty-text">暂无场景模板，点击「一键初始化」快速创建</text>
      </view>
    </view>

    <!-- Members Entry -->
    <view class="card members-entry" bindtap="goToMembers">
      <text>查看家庭成员</text>
      <text class="arrow-icon">&gt;</text>
    </view>
  </view>
</view>
