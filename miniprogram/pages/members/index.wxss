/* Members page styles - list layout */
.page-members {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ---- Loading ---- */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* ---- Card Base ---- */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

/* ---- Member List ---- */
.member-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.member-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.member-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-owner {
  background: #fff3e0;
  color: #e65100;
}

.tag-admin {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-member {
  background: #f5f5f5;
  color: #666666;
}

.member-perms {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.perm-badge {
  font-size: 20rpx;
  color: #07c160;
  background: #e8f5e9;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.member-email {
  font-size: 24rpx;
  color: #999999;
}

/* ---- Invite Entry ---- */
.invite-entry {
  margin-top: 24rpx;
}

.invite-entry-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx;
}

.invite-entry-left {
  display: flex;
  align-items: center;
}

.invite-entry-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.invite-entry-text {
  font-size: 30rpx;
  color: #07c160;
  font-weight: 500;
}

.invite-entry-arrow {
  font-size: 32rpx;
  color: #cccccc;
  flex-shrink: 0;
}

/* ---- Empty ---- */
.empty-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.empty-text {
  font-size: 28rpx;
  color: #bbbbbb;
}

/* ---- Role Picker ActionSheet ---- */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
}

.picker-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  padding: 24rpx 0 48rpx;
}

.picker-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  padding: 16rpx 32rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-option {
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333333;
  border-bottom: 2rpx solid #f5f5f5;
}

.picker-option:active {
  background: #f9f9f9;
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-cancel {
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999999;
  border-top: 12rpx solid #f5f5f5;
}

.picker-cancel:active {
  background: #f9f9f9;
}
