<!-- Members page: member list with roles, permissions, and invite entry -->
<view class="page-members">
  <!-- Loading state -->
  <view wx:if="{{loading}}" class="loading-container">
    <loading />
  </view>

  <!-- Main content -->
  <view wx:else class="members-content">
    <!-- Member List -->
    <view wx:if="{{members.length > 0}}" class="card member-list">
      <view
        wx:for="{{members}}"
        wx:key="member_id"
        class="member-item"
        data-member-id="{{item.member_id}}"
        bindtap="onMemberTap"
      >
        <!-- Avatar placeholder with first character -->
        <view class="member-avatar">
          <image wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder" style="background: {{item.color || '#07c160'}};">
            <text>{{item.nickname ? item.nickname.charAt(0).toUpperCase() : '?'}}</text>
          </view>
        </view>

        <!-- Member info -->
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{item.nickname || item.name || '未知用户'}}</text>
            <text class="member-tag tag-{{item.role}}">{{roleLabel(item.role)}}</text>
          </view>
          <view wx:if="{{item.email || item.permissions}}" class="member-perms">
            <text wx:if="{{item.email}}" class="member-email">{{item.email}}</text>
            <text wx:for="{{item.permissions || []}}" wx:key="*this" class="perm-badge">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty state -->
    <view wx:else class="empty-container">
      <text class="empty-text">暂无家庭成员</text>
    </view>

    <!-- Invite Code Entry -->
    <view class="card invite-entry" bindtap="goToFamily">
      <view class="invite-entry-inner">
        <view class="invite-entry-left">
          <view class="invite-entry-icon">🔗</view>
          <text class="invite-entry-text">邀请码管理</text>
        </view>
        <text class="invite-entry-arrow">&gt;</text>
      </view>
    </view>
  </view>

  <!-- Role picker action sheet -->
  <view wx:if="{{showRolePicker}}" class="picker-overlay" bindtap="closeRolePicker"></view>
  <view wx:if="{{showRolePicker}}" class="picker-sheet">
    <view class="picker-title">修改角色</view>
    <view
      wx:for="{{roleOptions}}"
      wx:key="*this"
      class="picker-option"
      data-role="{{item.value}}"
      bindtap="changeMemberRole"
    >
      {{item.label}}
    </view>
    <view class="picker-cancel" bindtap="closeRolePicker">取消</view>
  </view>
</view>
