/* Home page styles - card layout */
.page-home {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ---- Loading ---- */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* ---- Card base ---- */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ---- Family Card ---- */
.family-card {
  margin-bottom: 24rpx;
}

.family-card-header {
  display: flex;
  align-items: center;
}

.family-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #e8f5e9;
}

.family-avatar image {
  width: 100%;
  height: 100%;
}

.family-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.family-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-hint {
  font-size: 26rpx;
  color: #999999;
}

.arrow-icon {
  font-size: 32rpx;
  color: #cccccc;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ---- Quick Entries ---- */
.quick-entries {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.entry-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
}

.entry-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 12rpx;
}

.entry-label {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
}

/* ---- Section Title ---- */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-title-more {
  font-size: 26rpx;
  color: #07c160;
}

/* ---- Empty Card ---- */
.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbbbbb;
}

/* ---- Task List ---- */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.task-item-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.priority-0 {
  background: #e0e0e0;
}

.priority-1 {
  background: #07c160;
}

.priority-2 {
  background: #ffa726;
}

.priority-3 {
  background: #ef5350;
}

.task-item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.task-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-due {
  font-size: 24rpx;
  color: #999999;
}

.task-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-pending {
  background: #fff8e1;
  color: #f9a825;
}

.status-in_progress {
  background: #e3f2fd;
  color: #1e88e5;
}

.status-submitted {
  background: #f3e5f5;
  color: #8e24aa;
}
