/* Login page styles - centered layout, green theme */
.page-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #f0faf0 0%, #ffffff 40%);
  box-sizing: border-box;
}

/* ---- Brand Section ---- */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.brand-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
}

.brand-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: #999999;
  letter-spacing: 2rpx;
}

/* ---- Button Section ---- */
.button-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wechat-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #07c160;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  border: none;
  margin-bottom: 32rpx;
}

.btn-wechat-login::after {
  border: none;
}

.btn-wechat-login[disabled] {
  background: #a0e0b0;
}

.agreement-text {
  font-size: 24rpx;
  color: #cccccc;
  text-align: center;
}

.link {
  color: #07c160;
}
