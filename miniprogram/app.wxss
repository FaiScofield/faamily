/* 全局样式 - 家庭管家 */

page {
  --primary: #07c160;
  --primary-dark: #06ad56;
  --danger: #ee0a24;
  --warning: #ff976a;
  --text: #323233;
  --text-secondary: #969799;
  --text-light: #c8c9cc;
  --bg: #f7f8fa;
  --card-bg: #ffffff;
  --border: #ebedf0;
  --radius: 8px;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.06);

  font-size: 14px;
  color: var(--text);
  background: var(--bg);
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  margin: 12px 16px;
  padding: 16px;
  box-shadow: var(--shadow);
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

/* 按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 12px 24px;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.btn-primary:active {
  background: var(--primary-dark);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  line-height: 1.4;
}

.tag-pending { background: #fff3e0; color: #e65100; }
.tag-in_progress { background: #e3f2fd; color: #1565c0; }
.tag-submitted { background: #f3e5f5; color: #7b1fa2; }
.tag-done { background: #e8f5e9; color: #2e7d32; }
.tag-rejected { background: #fbe9e7; color: #bf360c; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  color: var(--text-secondary);
}

.empty-state text {
  margin-top: 12px;
  font-size: 14px;
}
